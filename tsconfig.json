{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@lynx-js/react",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedDeclarations": false,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "lynx.config.js"]
}
